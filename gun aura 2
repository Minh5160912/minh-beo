-- [[ CORE LOGIC ]] --
local function getCharacterFromPart(part)
    if not part then return nil end
    local character = part:FindFirstAncestorOfClass("Model")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    return (humanoid and character) and character or nil
end

local function fireStackedShot(targetPlayer, weaponTool)
    if not (combatRemote and targetPlayer and weaponTool) then return end
    
    local args = {
        [1] = targetPlayer,
        [2] = weaponTool,
        [3] = {
            ["Damage"] = Config.Damage,
            ["Critical"] = true
        }
    }

    -- Vòng lặp bắn theo số lượng stack đã chỉnh ở UI
    for i = 1, Config.StackAmount do
        combatRemote:FireServer(unpack(args))
    end
end

-- Input Listener
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or not Config.AuraEnabled then return end
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

    local character = player.Character
    local tool = character and character:FindFirstChildOfClass("Tool")
    if not tool then return end

    local targetModel = getCharacterFromPart(mouse.Target)
    if not targetModel or targetModel == character then return end

    local targetPlayer = Players:GetPlayerFromCharacter(targetModel)
    if targetPlayer then
        fireStackedShot(targetPlayer, tool)
    end
end)
local function bypassGunCooldowns()
    if WeaponData then
        for _, weapon in pairs(WeaponData) do
            if type(weapon) == "table" then
                -- Modern Blox Fruits naming conventions for cooldowns
                if weapon.Cooldown then weapon.Cooldown = 0 end
                if weapon.ReloadTime then weapon.ReloadTime = 0 end
                if weapon.FireRate then weapon.FireRate = 0 end
                if weapon.Delay then weapon.Delay = 0 end
            end
        end
    end
end
local function applyGunDamage()
    if not getgenv().GunAuraSettings.GunEnabled then return end
    
    local target, targetPart = findClosestTargetForGun()
    if not target or not targetPart then return end

    getgenv().GunAuraSettings.CurrentTarget = targetPart

    if ShootGunEvent then
        pcall(function()
            -- Increase to 5-10 for "Instant" kill effect, but don't overdo it
            for i = 1, 5 do 
                ShootGunEvent:FireServer(targetPart.Position, {targetPart})
            end
        end)
    end
end

-- [[ CORE LOGIC ]] --
local function getCharacterFromPart(part)
    if not part then return nil end
    local character = part:FindFirstAncestorOfClass("Model")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    return character
end

local function fireStackedShot(targetPlayer, weaponTool)
    if not (combatRemote and targetPlayer and weaponTool) then return end
    
    local targetChar = targetPlayer.Character
    local targetPart = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
    
    if not targetPart then return end

    task.spawn(function()
        for i = 1, Config.StackAmount do
            if not Config.AuraEnabled then break end
            
            -- Adjusted arguments to match typical BF requirements
            local args = {
                [1] = targetPart.Position,
                [2] = {targetPart}
            }
            combatRemote:FireServer(unpack(args))
            
            -- Prevent rate-limit kicks
            if i % 10 == 0 then task.wait() end
        end
    end)
end

-- Input Listener
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or not Config.AuraEnabled then return end
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

    local character = player.Character
    local tool = character and character:FindFirstChildOfClass("Tool")
    if not tool then return end

    local targetModel = getCharacterFromPart(mouse.Target)
    if not targetModel or targetModel == character then return end

    local targetPlayer = Players:GetPlayerFromCharacter(targetModel)
    if targetPlayer then
        fireStackedShot(targetPlayer, tool)
    end
end)


-- [[ BACKGROUND LOOPS ]] --
-- Loop cho Gun Aura
task.spawn(function()
    while task.wait(getgenv().GunAuraSettings.FireRate) do
        if getgenv().GunAuraSettings.GunEnabled then
            local myPos = Player.Character and Player.Character:GetPivot().Position
            if not myPos then continue end
            
            -- Tìm target gần nhất
            local closestDist = getgenv().GunAuraSettings.GunRange
            local closestPart = nil
            
            local targets = (getgenv().GunAuraSettings.TargetType == "NPC") and Enemies:GetChildren() or Characters:GetChildren()
            for _, v in pairs(targets) do
                local hrp = v:FindFirstChild("HumanoidRootPart")
                if hrp and (hrp.Position - myPos).Magnitude < closestDist then
                    closestPart = hrp
                end
            end
            
            if closestPart then
				getgenv().GunAuraSettings.CurrentTarget = closestPart
				local ShootEvent = ReplicatedStorage:FindFirstChild("RE/ShootGunEvent", true)
				if ShootEvent then 
					for i = 1, 3 do -- Gửi 3 gói tin mỗi lần lặp để dồn dame nhanh hơn
						ShootEvent:FireServer(closestPart.Position, {closestPart})
					end
				end
			end
        end
    end
end)

-- Loop cho Fast Click (Mouse Simulation)
task.spawn(function()
    while task.wait(0.001) do
        if _G.UltraClick then
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
    end
end)

-- Cooldown Bypass Loop
task.spawn(function()
    while task.wait(1) do
        if getgenv().GunAuraSettings.NoCooldown then
            pcall(function()
                local WeaponData = require(ReplicatedStorage.Modules.WeaponData)
                for _, v in pairs(WeaponData) do
                    if type(v) == "table" then
                        v.Cooldown = 0 v.ReloadTime = 0 v.FireRate = 0
                    end
                end
            end)
        end
    end
end)


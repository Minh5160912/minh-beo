local function GetPlayerData()
    local char = lp.Character
    local data = lp:FindFirstChild("Data")
    local stats = lp:FindFirstChild("leaderstats")
    
    local info = {
        level = data and data:FindFirstChild("Level") and data.Level.Value or 0,
        beli = data and data:FindFirstChild("Beli") and data.Beli.Value or 0,
        fruit = data and data:FindFirstChild("DevilFruit") and data.DevilFruit.Value or "None",
        race = data and data:FindFirstChild("Race") and data.Race.Value or "Human",
        bounty = stats and stats:FindFirstChild("Bounty/Honor") and stats["Bounty/Honor"].Value or 0,
        hp = 0, maxHp = 0, en = 0, maxEn = 0
    }

    if char and char:FindFirstChild("Humanoid") then
        info.hp = math.floor(char.Humanoid.Health)
        info.maxHp = math.floor(char.Humanoid.MaxHealth)
    end
    if char and char:FindFirstChild("Energy") then
        info.en = math.floor(char.Energy.Value)
        info.maxEn = math.floor(char.Energy.MaxValue)
    end
    return info
end


-- Fast Attack Logic
getgenv()._FastAttackBackup = getgenv()._FastAttackBackup or {}
local HITBOX = 100000
local LOOP_DELAY = 0.0001

local function safeRequireWeaponData()
    local ok, mod = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("WeaponData"))
    end)
    return ok and mod or nil
end

local WeaponData = safeRequireWeaponData()

local function findAttackMelee()
    if getgenv().attackMelee then return getgenv().attackMelee end
    if not getgc or not debug.getinfo then return nil end

    for _, v in next, getgc(true) do
        if typeof(v) == "function" then
            local ok, info = pcall(debug.getinfo, v)
            if ok and info and info.name == "attackMelee" then
                getgenv().attackMelee = v
                return v
            end
        end
    end
    return nil
end

local function applyFastUpvalues(fn)
    if not setupvalue or not getupvalues then return end
    local ok, uvs = pcall(getupvalues, fn)
    if not ok then return end
    for i, v in next, uvs do
        if type(v) == "number" and v > 0 and v < 5 then
            pcall(setupvalue, fn, i, 0)
        elseif type(v) == "boolean" and v == true then
            pcall(setupvalue, fn, i, false)
        end
    end
end

task.spawn(function()
    while task.wait(LOOP_DELAY) do
        if _G.UltraClick then
            pcall(function()
                local attackFn = findAttackMelee()
                if not attackFn or not lp.Character then return end
                
                local tool = lp.Character:FindFirstChildOfClass("Tool")
                if not tool or not WeaponData then return end

                local weaponName = tool:GetAttribute("WeaponName")
                local w = WeaponData[weaponName]
                if not w then return end

                if getgenv()._FastAttackBackup.Hitbox == nil then
                    getgenv()._FastAttackBackup.Hitbox = w.HitboxMagnitude
                end

                applyFastUpvalues(attackFn)
                w.HitboxMagnitude = HITBOX

                VIM:SendMouseButtonEvent(0, 0, 0, true, lp.PlayerGui, 0)
                VIM:SendMouseButtonEvent(0, 0, 0, false, lp.PlayerGui, 0)
                attackFn()
            end)
        end
    end
end)

-- Gun Aura Logic
local function IsAlive(character)
    local hum = character and character:FindFirstChild("Humanoid")
    return hum and hum.Health > 0
end

local function findClosestTargetForGun()
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position

    local closestDist = getgenv().GunAuraSettings.GunRange
    local closestTarget, closestPart = nil, nil
    local targetType = getgenv().GunAuraSettings.TargetType

    local function checkCollection(folder)
        for _, obj in ipairs(folder:GetChildren()) do
            if IsAlive(obj) and obj ~= char then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                if hrp then
                    local dist = (hrp.Position - myPos).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closestTarget = obj
                        closestPart = hrp
                    end
                end
            end
        end
    end

    if targetType == "NPC" or targetType == "All" then checkCollection(Enemies) end
    if targetType == "Player" or targetType == "All" then checkCollection(Characters) end

    return closestTarget, closestPart
end

